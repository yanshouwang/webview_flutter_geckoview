{
  "manifest_version": 2,
  "name": "messaging",
  "version": "1.0",
  "description": "Messaging web extension.",
  "browser_specific_settings": {
    "gecko": {
      "id": "messaging@zeekr.dev"
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "permissions": [
    "nativeMessaging",
    "nativeMessagingFromContent",
    "geckoViewAddons",
    "<all_urls>"
  ]
}