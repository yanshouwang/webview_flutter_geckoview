{
  "manifest_version": 2,
  "name": "messaging",
  "version": "1.0",
  "description": "Messaging web extension.",
  "browser_specific_settings": {
    "gecko": {
      "id": "messaging@zeekr.dev"
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "permissions": [
    "tabs",
    "nativeMessaging",
    "geckoViewAddons",
    "<all_urls>"
  ]
}